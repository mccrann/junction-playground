# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will never be committed.

# Your Junction API key — https://junction.health
JUNCTION_API_KEY=your_junction_api_key_here

# Base URL for internal Next.js API route calls during SSR (no trailing slash)
# Leave as-is for local dev; set to your deployment URL in production.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# The default Junction user ID to display on the dashboard.
JUNCTION_DEFAULT_USER_ID=your_user_id_here

# (Optional) Override the Junction API base URL, e.g. for the sandbox environment.
# JUNCTION_BASE_URL=https://api.sandbox.junction.health/v1
